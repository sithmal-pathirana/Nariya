{
  "manifest_version": 3,
  "name": "Nariya",
  "description": "Developer tool combining Requestly-style request management with Burp Suite-style deep network inspection.",
  "version": "0.1.0",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "webRequest",
    "debugger",
    "scripting",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "ui/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "ui/dashboard/dashboard.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "sandbox": {
    "pages": ["ui/sandbox.html"]
  },
  "web_accessible_resources": [
    {
      "resources": ["content/interceptor.js", "ui/sandbox.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
